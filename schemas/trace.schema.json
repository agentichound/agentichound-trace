{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentichound.dev/schemas/trace.schema.json",
  "title": "AgenticHound Trace Schema v0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run",
    "spans",
    "events",
    "errors",
    "usage"
  ],
  "properties": {
    "schema_version": {
      "const": "v0"
    },
    "run": {
      "$ref": "#/$defs/run"
    },
    "spans": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/span"
      }
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/event"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/error"
      }
    },
    "usage": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/usage"
      }
    }
  },
  "$defs": {
    "id_run": {
      "type": "string",
      "pattern": "^run_[A-Za-z0-9_-]+$"
    },
    "id_span": {
      "type": "string",
      "pattern": "^spn_[A-Za-z0-9_-]+$"
    },
    "id_event": {
      "type": "string",
      "pattern": "^evt_[A-Za-z0-9_-]+$"
    },
    "id_error": {
      "type": "string",
      "pattern": "^err_[A-Za-z0-9_-]+$"
    },
    "id_usage": {
      "type": "string",
      "pattern": "^use_[A-Za-z0-9_-]+$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "model",
        "tool",
        "orchestration",
        "retry",
        "handoff",
        "approval"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "error",
        "cancelled"
      ]
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "started_at",
        "ended_at",
        "duration_ms",
        "status"
      ],
      "properties": {
        "run_id": {
          "$ref": "#/$defs/id_run"
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "ended_at": {
          "type": "string",
          "format": "date-time"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "status": {
          "$ref": "#/$defs/status"
        }
      }
    },
    "span": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "span_id",
        "run_id",
        "parent_span_id",
        "retry_of_span_id",
        "kind",
        "name",
        "started_at",
        "ended_at",
        "duration_ms",
        "status"
      ],
      "properties": {
        "span_id": {
          "$ref": "#/$defs/id_span"
        },
        "run_id": {
          "$ref": "#/$defs/id_run"
        },
        "parent_span_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/id_span"
            },
            {
              "type": "null"
            }
          ]
        },
        "retry_of_span_id": {
          "anyOf": [
            {
              "$ref": "#/$defs/id_span"
            },
            {
              "type": "null"
            }
          ]
        },
        "kind": {
          "$ref": "#/$defs/kind"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "ended_at": {
          "type": "string",
          "format": "date-time"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "status": {
          "$ref": "#/$defs/status"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "retry"
              }
            }
          },
          "then": {
            "properties": {
              "retry_of_span_id": {
                "$ref": "#/$defs/id_span"
              }
            }
          },
          "else": {
            "properties": {
              "retry_of_span_id": {
                "type": "null"
              }
            }
          }
        }
      ]
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "run_id",
        "span_id",
        "kind",
        "ts",
        "payload"
      ],
      "properties": {
        "event_id": {
          "$ref": "#/$defs/id_event"
        },
        "run_id": {
          "$ref": "#/$defs/id_run"
        },
        "span_id": {
          "$ref": "#/$defs/id_span"
        },
        "kind": {
          "$ref": "#/$defs/kind"
        },
        "ts": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "error_id",
        "run_id",
        "span_id",
        "ts",
        "code",
        "message",
        "retryable"
      ],
      "properties": {
        "error_id": {
          "$ref": "#/$defs/id_error"
        },
        "run_id": {
          "$ref": "#/$defs/id_run"
        },
        "span_id": {
          "$ref": "#/$defs/id_span"
        },
        "ts": {
          "type": "string",
          "format": "date-time"
        },
        "code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "retryable": {
          "type": "boolean"
        }
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "usage_id",
        "run_id",
        "span_id",
        "kind",
        "prompt_tokens",
        "completion_tokens",
        "total_tokens",
        "estimated_cost_usd",
        "currency"
      ],
      "properties": {
        "usage_id": {
          "$ref": "#/$defs/id_usage"
        },
        "run_id": {
          "$ref": "#/$defs/id_run"
        },
        "span_id": {
          "$ref": "#/$defs/id_span"
        },
        "kind": {
          "type": "string",
          "enum": [
            "model",
            "tool"
          ]
        },
        "prompt_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "completion_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "total_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "estimated_cost_usd": {
          "type": "number",
          "minimum": 0
        },
        "currency": {
          "type": "string",
          "const": "USD"
        }
      }
    }
  }
}
